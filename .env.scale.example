ARANGO_ROOT_PASSWORD=replace-with-a-secret
ROUTING_INTERNAL_TOKEN=replace-with-a-long-random-token
EVENT_PSEUDONYM_SECRET=replace-with-a-separate-long-random-token
ADMIN_TOKEN=replace-with-a-separate-superadmin-token
ROUTING_DATASET_IDS=dataset_masjid_imosque_table_mosque_dki_jakarta_1
PUBLIC_API_BASE=https://api.example.id
DEPLOYMENT_VERSION=git-commit-sha
IMOSQUE_CORRIDOR_CACHE_DIR=/srv/data/osm_cache/route_corridors
IMOSQUE_CORRIDOR_MAX_GRAPHS=256
IMOSQUE_CORRIDOR_GRID_DEGREES=0.025
IMOSQUE_CORRIDOR_MIN_BUFFER_KM=2.5
IMOSQUE_CORRIDOR_MAX_BUFFER_KM=6
IMOSQUE_CORRIDOR_TARGET_AREA_KM2=350
IMOSQUE_CORRIDOR_MAX_CONCURRENT_BUILDS=1

# Leave empty when starting without the realtime profile. For a local Kafka
# profile use kafka:9092 inside Compose.
KAFKA_BOOTSTRAP_SERVERS=

# Images are overridable so production can pin approved, scanned digests.
ARANGO_IMAGE=arangodb:3.11.8
KAFKA_IMAGE=apache/kafka:4.3.0
